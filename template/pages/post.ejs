<!-- post.ejs -->
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="color-scheme" content="light dark">
    <link rel="stylesheet" href="<%= asset('/css/post-style.css') %>">
    <link rel="icon" type="image/png" href="<%= asset('/img/favicon.png') %>">
    <title>
        <%=title%>
    </title>
    <% if(containsCode) { %>
        <link href="<%- asset('@highlight.js/styles/atom-one-light.css') %>" rel="stylesheet">
        <% } %>
</head>

<!-- 返回顶部按钮 -->
<button id="backToTopBtn" class="back-to-top-btn" title="回到顶部">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M7 15L12 10L17 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
</button>

<body>
    <div class="essay-header-container">
        <a href="../index.html">
            <img src="<%= asset('/img/essays-header.png') %>" alt="Essays Header" class="header-image">
        </a>
    </div>
    <div class="container">
        <div class="essay-item-container">
            <!-- 标题 -->
            <div class="essay-item-title">
                <%=title%>
            </div>
            <!-- 日期 -->
            <div class="essay-item-date">
                <%= new Intl.DateTimeFormat('zh-CN', { year: 'numeric' , month: 'long' , day: 'numeric' ,
                    hour: '2-digit' , minute: '2-digit' }).format(creationDate) %>
            </div>
            <!-- 内容 -->
            <div class="essay-item-content">
                <%-contentHtml%>
            </div>
            <!-- 标签 -->
            <div class="essay-item-tags">
                <%for(let tag of tags) {%>
                    <span>
                        <%=tag.title%>
                    </span>
                    <% } %>
            </div>
        </div>
    </div>
    <footer class="miscc-footer">
        Powered by <a href="https://github.com/wiomoc/miscc" class="miscc-link">miscc</a> version <%= MISCC_VERSION%>
    </footer>
</body>

</html>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const backToTopBtn = document.getElementById('backToTopBtn');
    
    // 监听滚动事件，控制按钮显示隐藏
    window.addEventListener('scroll', function() {
        if (window.pageYOffset > 300) {
            backToTopBtn.classList.remove('hidden');
        } else {
            backToTopBtn.classList.add('hidden');
        }
    });
    
    // 点击按钮回到顶部
    backToTopBtn.addEventListener('click', function() {
        window.scrollTo({
            top: 0,
            behavior: 'smooth'
        });
    });
});
</script>